# ============================================================
# LLM 配置（用于 AI 分镜脚本生成）
# ============================================================

# LLM 平台: deepseek / glm / kimi / openai / custom
LLM_PROVIDER=deepseek

# LLM API Key（必填）
# DeepSeek: https://platform.deepseek.com/
# GLM(智谱): https://open.bigmodel.cn/
# Kimi(月之暗面): https://platform.moonshot.cn/
LLM_API_KEY=your_llm_api_key

# LLM 模型名称（可选，不填则使用平台默认模型）
# DeepSeek: deepseek-chat, deepseek-reasoner
# GLM: glm-4-flash, glm-4-plus
# Kimi: moonshot-v1-8k, moonshot-v1-32k
# LLM_MODEL=deepseek-chat

# LLM API 地址（可选，不填则使用平台默认地址）
# 填写后可接入任何 OpenAI 兼容的 API
# LLM_BASE_URL=https://api.deepseek.com

# ============================================================
# 视频生成 API（选择其一或全部）
# ============================================================

# 方式1: 即梦 (Dreamina) - 推荐，通过火山引擎官方 API
# 获取方式:
#   1. 注册火山引擎账号: https://console.volcengine.com/
#   2. 开通「即梦AI」或「智能视觉」服务
#   3. 在控制台 → 密钥管理 中获取 AK/SK
VOLC_ACCESS_KEY=your_access_key
VOLC_SECRET_KEY=your_secret_key

# 即梦视频模型（可选）
# 可选值: jimeng_t2v_v30 (3.0标准), jimeng_t2v_v30_pro (3.0 Pro)
JIMENG_MODEL=jimeng_t2v_v30

# 方式2: Runway Gen-3
RUNWAY_API_KEY=your_runway_api_key

# 方式3: Pika Labs
PIKA_API_KEY=your_pika_api_key

# 指定视频生成平台 (可选): auto / dreamina / runway / pika
VIDEO_PROVIDER=auto

# 可选：热点获取 API
NEWS_API_KEY=your_newsapi_key

# 可选：代理设置
HTTP_PROXY=
HTTPS_PROXY=