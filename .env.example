# ============================================================
# LLM 配置（用于 AI 分镜脚本生成）
# ============================================================

# LLM 平台: deepseek / glm / kimi / openai / custom
LLM_PROVIDER=deepseek

# LLM API Key（必填）
# DeepSeek: https://platform.deepseek.com/
# GLM(智谱): https://open.bigmodel.cn/
# Kimi(月之暗面): https://platform.moonshot.cn/
LLM_API_KEY=your_llm_api_key

# LLM 模型名称（可选，不填则使用平台默认模型）
# DeepSeek: deepseek-chat, deepseek-reasoner
# GLM: glm-4-flash, glm-4-plus
# Kimi: moonshot-v1-8k, moonshot-v1-32k
# LLM_MODEL=deepseek-chat

# LLM API 地址（可选，不填则使用平台默认地址）
# 填写后可接入任何 OpenAI 兼容的 API
# LLM_BASE_URL=https://api.deepseek.com

# ============================================================
# 视频生成 API（选择其一或全部）
# ============================================================

# 方式1: 即梦 (Dreamina) - 推荐，通过火山引擎官方 API
# 获取方式:
#   1. 注册火山引擎账号: https://console.volcengine.com/
#   2. 开通「即梦AI」或「智能视觉」服务
#   3. 在控制台 → 密钥管理 中获取 AK/SK
VOLC_ACCESS_KEY=your_access_key
VOLC_SECRET_KEY=your_secret_key

# 即梦视频模型（可选）
# 可选值: jimeng_t2v_v30 (3.0标准), jimeng_t2v_v30_pro (3.0 Pro)
JIMENG_MODEL=jimeng_t2v_v30

# 方式2: Runway Gen-3
RUNWAY_API_KEY=your_runway_api_key

# 方式3: Pika Labs
PIKA_API_KEY=your_pika_api_key

# 指定视频生成平台 (可选): dreamina / auto / runway / pika
# 当前项目默认优先走即梦
VIDEO_PROVIDER=dreamina

# ============================================================
# 音频生成配置（可选，用于旁白和背景音乐）
# ============================================================

# 火山引擎 TTS（语音合成）
# 获取方式:
#   1. 注册火山引擎账号: https://console.volcengine.com/
#   2. 开通「大模型语音合成」服务
#   3. 在控制台 → 语音技术 → 密钥管理 中获取 App ID 和 Access Token
VOLC_TTS_APP_ID=your_tts_app_id
VOLC_TTS_ACCESS_TOKEN=your_tts_access_token
VOLC_TTS_DEFAULT_VOICE=zh_female_shuangkuaisisi_moon_bigtts

# Suno API（AI 音乐生成 - 可选）
# SUNO_API_KEY=your_suno_key

# Stable Audio API（AI 音乐生成 - 可选）
# STABLE_AUDIO_API_KEY=your_stable_audio_key

# 本地音乐库路径（可选）
MUSIC_LIBRARY_PATH=assets/music

# ============================================================
# 角色一致性配置（可选）
# ============================================================

# 角色图片生成方式:
# signed_aksk: 使用火山视觉签名接口（当前已验证可用）
# ark: 使用新版 Ark 图片接口
# legacy: 使用旧版 VisualService 异步接口
CHARACTER_IMAGE_PROVIDER=signed_aksk

# 角色图片生成模型 req_key
# 当前已验证可用: jimeng_t2i_v40
CHARACTER_IMAGE_MODEL=jimeng_t2i_v40

# 即梦图片4.0在“参考图 + prompt”场景下需要 image_urls
# 所以如果你要让“上传角色图 -> 生成分镜图”真正使用参考图，
# 需要把 output 目录通过公网 URL 暴露出来，例如：
# PUBLIC_ASSET_BASE_URL=https://xxxx.ngrok-free.app/media
PUBLIC_ASSET_BASE_URL=

# 可选：Ark 图片接口（仅在 CHARACTER_IMAGE_PROVIDER=ark 时使用）
# ARK_API_KEY=your_ark_api_key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 角色图片输出目录
CHARACTER_IMAGE_DIR=output/characters

# ============================================================
# 视频合成配置（可选）
# ============================================================

# FFmpeg 路径（如果不在系统 PATH 中）
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# 视频/音频编码器
VIDEO_CODEC=libx264
AUDIO_CODEC=aac

# ============================================================
# 其他配置
# ============================================================

# 可选：热点获取 API
NEWS_API_KEY=your_newsapi_key

# 可选：代理设置
HTTP_PROXY=
HTTPS_PROXY=
