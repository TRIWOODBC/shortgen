# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# 视频生成 API（选择其一或全部）
# 方式1: 即梦 (Dreamina) - 推荐国内用户使用
# 获取方式: 登录 https://jimeng.jianying.com/ 后从浏览器 Cookie 中提取
DREAMINA_SESSION_ID=your_session_id
DREAMINA_UID=your_uid
DREAMINA_DID=your_did

# 方式2: Runway Gen-3
RUNWAY_API_KEY=your_runway_api_key

# 方式3: Pika Labs
PIKA_API_KEY=your_pika_api_key

# 指定视频生成平台 (可选): auto / dreamina / runway / pika
VIDEO_PROVIDER=auto

# 可选：热点获取 API
NEWS_API_KEY=your_newsapi_key

# 可选：代理设置
HTTP_PROXY=
HTTPS_PROXY=